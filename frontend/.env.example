# Copy to `.env.local` for overrides. In dev, API calls are proxied to the
# backend via Vite (see vite.config.ts), so this can usually stay empty.
# For a split deploy (static host like Vercel/Netlify), set this at build time
# to your backend URL, e.g. https://spoken-backend.onrender.com
VITE_API_BASE_URL=
